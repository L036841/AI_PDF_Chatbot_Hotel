# Copy this file to .env and fill in your values.
# Never commit the real .env to source control.

# Azure AD credentials
CLIENT_ID=your-azure-client-id
CLIENT_SECRET=your-azure-client-secret
TENANT_ID=your-azure-tenant-id

# LLM Gateway
LLM_GATEWAY_KEY=your-llm-gateway-api-key
GATEWAY_BASE_URL=https://gateway.apim.lilly.com/llm-gateway
GATEWAY_SCOPE=api://llm-gateway.lilly.com/.default
DEFAULT_MODEL=gpt-5.1-2025-11-13
